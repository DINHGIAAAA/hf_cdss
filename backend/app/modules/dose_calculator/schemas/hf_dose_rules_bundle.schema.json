{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hf-cdss.local/schemas/hf_dose_rules_bundle.schema.json",
  "title": "HF dose rules bundle",
  "type": "object",
  "required": ["version", "rules"],
  "additionalProperties": true,
  "properties": {
    "version": {
      "type": "string",
      "minLength": 1,
      "pattern": "^hf_dose_rules_v[0-9]+$"
    },
    "source": {
      "type": "string"
    },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/dose_rule"
      }
    }
  },
  "$defs": {
    "dose_amount": {
      "type": "object",
      "required": ["value", "unit"],
      "additionalProperties": true,
      "properties": {
        "value": { "type": "number" },
        "unit": { "type": "string", "minLength": 1 },
        "frequency": { "type": "string" },
        "label": { "type": "string" }
      }
    },
    "dose_rule": {
      "type": "object",
      "required": ["rule_id", "drug_keys", "calculation_type"],
      "additionalProperties": true,
      "properties": {
        "rule_id": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[a-z0-9_]+$"
        },
        "drug_keys": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "drug_class": { "type": "string" },
        "calculation_type": {
          "type": "string",
          "enum": [
            "fixed_titration",
            "weight_adjusted_target",
            "crcl_bracket",
            "dual_criteria_reduction",
            "criteria_reduction",
            "crcl_threshold_dose",
            "dabigatran_dose",
            "congestion_range",
            "fixed_dose",
            "step_titration",
            "warfarin_inr"
          ]
        },
        "evidence_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "monitoring": {
          "type": "array",
          "items": { "type": "string" }
        },
        "rationale": { "type": "string" },
        "starting_dose": { "$ref": "#/$defs/dose_amount" },
        "target_dose": { "$ref": "#/$defs/dose_amount" },
        "recommended_dose": { "$ref": "#/$defs/dose_amount" },
        "dose_steps": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/dose_amount" }
        }
      }
    }
  }
}
