HF_CDSS_PROJECT_NAME="Heart Failure CDSS"
HF_CDSS_VERSION="0.1.0"
HF_CDSS_ENVIRONMENT="development"
HF_CDSS_CORS_ORIGINS='["http://localhost:5173","http://127.0.0.1:5173"]'
HF_CDSS_LOG_LEVEL="INFO"
HF_CDSS_API_KEYS="change-me"
HF_CDSS_API_KEY_HEADER="x-api-key"
HF_CDSS_MAX_REQUEST_BODY_BYTES="1000000"
# Optional: only required when overriding HF_CDSS_LLM_BASE_URL to api.openai.com
HF_CDSS_OPENAI_API_KEY=""
HF_CDSS_LLM_BASE_URL="http://localhost:11434/v1"
HF_CDSS_LLM_MODEL="qwen2.5:7b"
HF_CDSS_LLM_API_TYPE="chat_completions"
HF_CDSS_LLM_TIMEOUT_SECONDS="90"
HF_CDSS_CLINICAL_INTAKE_LLM_TIMEOUT_SECONDS="90"
HF_CDSS_CLINICAL_INTAKE_LLM_MAX_TOKENS="700"
HF_CDSS_CLINICAL_INTAKE_SEMANTIC_ENABLED="true"
HF_CDSS_CLINICAL_INTAKE_SEMANTIC_THRESHOLD="0.52"
HF_CDSS_CLINICAL_INTAKE_HISTORY_ENABLED="true"
HF_CDSS_CLINICAL_INTAKE_HISTORY_MAX_MESSAGES="12"
HF_CDSS_CLINICAL_INTAKE_HISTORY_RELEVANCE_THRESHOLD="0.38"
HF_CDSS_CLINICAL_INTAKE_SELECTIVE_LLM_ENABLED="true"
HF_CDSS_CLINICAL_INTAKE_SELECTIVE_MIN_CONFIDENCE="0.75"
HF_CDSS_CLINICAL_INTAKE_SELECTIVE_SIMPLE_MISSING_MAX="3"
HF_CDSS_CLINICAL_INTAKE_SELECTIVE_COMPLEXITY_WORD_THRESHOLD="80"
HF_CDSS_EMBEDDING_PROVIDER="ollama"
HF_CDSS_EMBEDDING_BASE_URL="http://localhost:11434"
HF_CDSS_EMBEDDING_MODEL="bge-m3"
# Stage 1 ANN pool size before cross-encoder rerank (default 50)
HF_CDSS_SEMANTIC_RERANK_ENABLED="true"
HF_CDSS_SEMANTIC_RERANK_PROVIDER="cohere"
HF_CDSS_SEMANTIC_RERANK_CANDIDATES="50"
# Cohere cross-encoder rerank (Stage 2). Requires internet access.
HF_CDSS_COHERE_API_KEY=""
HF_CDSS_COHERE_RERANK_MODEL="rerank-v3.5"
HF_CDSS_COHERE_RERANK_TIMEOUT_SECONDS="30"
HF_CDSS_COHERE_RERANK_WEIGHT="0.85"
# Fallback bi-encoder rerank settings when Cohere is unavailable
HF_CDSS_SEMANTIC_RERANK_WEIGHT="0.75"
HF_CDSS_LLM_CACHE_ENABLED="true"
HF_CDSS_LLM_CACHE_TTL_SECONDS="600"
HF_CDSS_LLM_CACHE_MAX_ENTRIES="128"
HF_CDSS_REDIS_URL="redis://:change-me@localhost:6379/0"
REDIS_PASSWORD="change-me"
HF_CDSS_JWT_SECRET_KEY="change-me-in-production"
HF_CDSS_JWT_ALGORITHM="HS256"
HF_CDSS_JWT_ACCESS_TOKEN_EXPIRE_MINUTES="60"
HF_CDSS_AUTH_LOGIN_ENABLED="true"
# Copy from backend/app/data/seed_users.example.json for local bootstrap, or leave empty.
HF_CDSS_AUTH_SEED_USERS_JSON=""
HF_CDSS_POSTGRES_DSN="postgresql://hf_cdss:hf_cdss@localhost:55432/hf_cdss"
HF_CDSS_NEO4J_URI="bolt://localhost:7687"
HF_CDSS_NEO4J_USER="neo4j"
HF_CDSS_NEO4J_PASSWORD="password"
HF_CDSS_CHROMA_HOST="localhost"
HF_CDSS_CHROMA_PORT="8001"
HF_CDSS_CHROMA_COLLECTION="heart_failure_evidence"
HF_CDSS_DATASTORE_BOOTSTRAP_ON_STARTUP="true"
HF_CDSS_RETRIEVAL_BACKEND="hybrid"
HF_CDSS_ARTIFACT_STORAGE="s3"
HF_CDSS_ARTIFACT_CACHE_ROOT="./.cache/hf_cdss/heart_failure"
HF_CDSS_S3_ENDPOINT_URL="http://localhost:4566"
HF_CDSS_RAW_BUCKET="hf-cdss-raw"
HF_CDSS_PROCESSED_BUCKET="hf-cdss-processed"
HF_CDSS_S3_PREFIX="heart_failure"
HF_CDSS_KAFKA_BOOTSTRAP_SERVERS="localhost:9092"
HF_CDSS_KAFKA_IMPORTANT_SECTIONS_TOPIC="important_sections"
HF_CDSS_AWS_ACCESS_KEY_ID="test"
HF_CDSS_AWS_SECRET_ACCESS_KEY="test"
HF_CDSS_AWS_DEFAULT_REGION="us-east-1"
HF_CDSS_POSTGRES_AUDIT_ENABLED="true"
HF_CDSS_AUDIT_SCHEMA_VERSION="2026-06-12"
HF_CDSS_RATE_LIMIT_REQUESTS="60"
HF_CDSS_RATE_LIMIT_WINDOW_SECONDS="60"
HF_CDSS_ADMIN_RATE_LIMIT_REQUESTS="10"
HF_CDSS_ADMIN_RATE_LIMIT_WINDOW_SECONDS="60"
HF_CDSS_POSTGRES_POOL_MIN_SIZE="1"
HF_CDSS_POSTGRES_POOL_MAX_SIZE="5"
HF_CDSS_VERIFICATION_AGENT_MODE="hybrid"
HF_CDSS_VERIFICATION_AGENT_MODEL="qwen2.5:1.5b"
HF_CDSS_VERIFICATION_AGENT_MAX_ITERATIONS="1"
HF_CDSS_VERIFICATION_AGENT_MAX_TOKENS="140"
HF_CDSS_VERIFICATION_AGENT_TIMEOUT_SECONDS="180"
HF_CDSS_VERIFICATION_AGENT_WORKERS="2"
HF_CDSS_VERIFICATION_AGENT_LLM_AGENTS="evidence_agent,guideline_alignment_agent"
HF_CDSS_VERIFICATION_AGENT_TOOL_MODE="direct"
HF_CDSS_VERIFICATION_RETRIEVAL_TOP_K="3"
HF_CDSS_VERIFICATION_CACHE_ENABLED="true"
HF_CDSS_VERIFICATION_CACHE_TTL_SECONDS="300"
HF_CDSS_VERIFICATION_CACHE_MAX_ENTRIES="128"

# Frontend (leave VITE_API_BASE_URL empty for same-origin proxy + session cookies)
# VITE_API_BASE_URL=""
VITE_ADMIN_BASE_URL="http://127.0.0.1:5174"
VITE_DOCTOR_DASHBOARD_URL="http://127.0.0.1:5173"
VITE_CHAT_LANGUAGE="vi"
OLLAMA_MODEL="qwen2.5:7b"
OLLAMA_AGENT_MODEL="qwen2.5:1.5b"
AIRFLOW_ADMIN_USER="admin"
AIRFLOW_ADMIN_PASSWORD="admin"
HF_CDSS_DOSE_CALCULATOR_ENABLED=true
HF_CDSS_DOSE_RULES_ACTIVE_BUNDLE_VERSION=v1
# Optional overrides for bundled fallback (Postgres approved rows take precedence)
# HF_CDSS_DOSE_RULES_BUNDLE_PATH=
# HF_CDSS_DOSE_RULES_BUNDLE_DIR=
HF_CDSS_DOSE_RULES_VALIDATION_STRICT=true
HF_CDSS_DOSE_RULES_CACHE_TTL_SECONDS=300
HF_CDSS_INTERACTION_RULES_CACHE_TTL_SECONDS=300
HF_CDSS_GDMT_POLICY_CACHE_TTL_SECONDS=300
HF_CDSS_DOSE_SAFETY_WARNINGS_CACHE_TTL_SECONDS=300
HF_CDSS_KG_DOSE_OVERLAYS_CACHE_TTL_SECONDS=300
HF_CDSS_GOVERNANCE_CIRCUIT_BREAKER_ENABLED=true
HF_CDSS_GOVERNANCE_DB_TIMEOUT_SECONDS=2.5
HF_CDSS_GOVERNANCE_CIRCUIT_FAILURE_THRESHOLD=3
HF_CDSS_GOVERNANCE_CIRCUIT_RECOVERY_SECONDS=30

# HyDE query expansion for GraphRAG (adds LLM call per eligible chat query)
HF_CDSS_HYDE_RETRIEVAL_ENABLED=true
HF_CDSS_HYDE_RETRIEVAL_MODEL="qwen2.5:1.5b"
HF_CDSS_HYDE_RETRIEVAL_TIMEOUT_SECONDS="20"
HF_CDSS_HYDE_RETRIEVAL_MAX_TOKENS="220"
HF_CDSS_HYDE_RETRIEVAL_CACHE_TTL_SECONDS="600"
HF_CDSS_HYDE_RETRIEVAL_MIN_QUERY_CHARS="8"
HF_CDSS_HYDE_RETRIEVAL_COMBINE_BASELINE=true

# GraphRAG retrieval tuning
HF_CDSS_GRAPHRAG_MULTI_QUERY_ENABLED=true
HF_CDSS_GRAPHRAG_RRF_K="60"
HF_CDSS_GRAPHRAG_CHUNK_WINDOW_SIZE="1"
HF_CDSS_GRAPHRAG_ADAPTIVE_TOP_K=true
HF_CDSS_GRAPHRAG_GRAPH_GUIDED_FILTER_ENABLED=true
# Clinical entity boosting (tiered weights + patient threshold/section affinity)
HF_CDSS_CLINICAL_ENTITY_BOOST_LAB_CRITICAL_WEIGHT=0.12
HF_CDSS_CLINICAL_ENTITY_BOOST_LAB_MONITOR_WEIGHT=0.06
HF_CDSS_CLINICAL_ENTITY_BOOST_DRUG_CLASS_WEIGHT=0.10
HF_CDSS_CLINICAL_ENTITY_BOOST_DRUG_NAME_WEIGHT=0.08
HF_CDSS_CLINICAL_ENTITY_BOOST_CONDITION_WEIGHT=0.05
HF_CDSS_CLINICAL_ENTITY_BOOST_SAFETY_WEIGHT=0.09
HF_CDSS_CLINICAL_ENTITY_BOOST_GENERAL_WEIGHT=0.03
HF_CDSS_CLINICAL_ENTITY_THRESHOLD_BOOST_MAX=0.22
HF_CDSS_CLINICAL_ENTITY_PATIENT_CRITICAL_MULTIPLIER=1.65
HF_CDSS_CLINICAL_ENTITY_PATIENT_LAB_AFFINITY_MULTIPLIER=1.40
HF_CDSS_CLINICAL_ENTITY_SECTION_RENAL_BOOST=0.07
