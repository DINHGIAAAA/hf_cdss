# Copy to .env and set secrets before running locally.
#
# Tuning (GraphRAG, clinical boosting, rate limits, HyDE, verification agents, …)
# uses defaults in backend/app/core/config.py. Override any HF_CDSS_* var via env only when needed.

# --- Environment ---
HF_CDSS_ENVIRONMENT=development

# --- Security & auth ---
HF_CDSS_API_KEYS=change-me
HF_CDSS_JWT_SECRET_KEY=change-me-in-production
HF_CDSS_REDIS_URL=redis://localhost:6379/0
# Optional: copy backend/app/data/seed_users.example.json for local login bootstrap
HF_CDSS_AUTH_SEED_USERS_JSON=

# --- LLM ---
HF_CDSS_LLM_BASE_URL=http://localhost:11434/v1
HF_CDSS_LLM_MODEL=qwen2.5:7b
# HF_CDSS_OPENAI_API_KEY=          # only when HF_CDSS_LLM_BASE_URL points to api.openai.com

# --- Embeddings ---
HF_CDSS_EMBEDDING_BASE_URL=http://localhost:11434
HF_CDSS_EMBEDDING_MODEL=bge-m3

# --- Optional rerank (requires internet) ---
# HF_CDSS_COHERE_API_KEY=

# --- Databases & vector store ---
HF_CDSS_POSTGRES_DSN=postgresql://hf_cdss:hf_cdss@localhost:55432/hf_cdss
HF_CDSS_NEO4J_URI=bolt://localhost:7687
HF_CDSS_NEO4J_USER=neo4j
HF_CDSS_NEO4J_PASSWORD=password
HF_CDSS_CHROMA_HOST=localhost
HF_CDSS_CHROMA_PORT=8001
HF_CDSS_CHROMA_COLLECTION=heart_failure_evidence

# --- Artifacts (LocalStack / S3) ---
HF_CDSS_ARTIFACT_CACHE_ROOT=./.cache/hf_cdss/heart_failure
HF_CDSS_S3_ENDPOINT_URL=http://localhost:4566
HF_CDSS_RAW_BUCKET=hf-cdss-raw
HF_CDSS_PROCESSED_BUCKET=hf-cdss-processed
HF_CDSS_S3_PREFIX=heart_failure
HF_CDSS_AWS_ACCESS_KEY_ID=test
HF_CDSS_AWS_SECRET_ACCESS_KEY=test
HF_CDSS_AWS_DEFAULT_REGION=us-east-1

# --- Retrieval backend: local | hybrid | databases ---
HF_CDSS_RETRIEVAL_BACKEND=hybrid

# --- Frontend (Vite build / dev) ---
# VITE_API_BASE_URL=               # empty = same-origin proxy
VITE_ADMIN_BASE_URL=http://127.0.0.1:5174
VITE_DOCTOR_DASHBOARD_URL=http://127.0.0.1:5173

# --- Local tooling (Ollama, Airflow Docker) ---
OLLAMA_MODEL=qwen2.5:7b
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin
