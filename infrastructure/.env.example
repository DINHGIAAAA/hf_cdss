HF_CDSS_ENVIRONMENT=docker
HF_CDSS_CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
HF_CDSS_OPENAI_API_KEY=
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_AGENT_MODEL=qwen2.5:1.5b
OLLAMA_KEEP_ALIVE=24h
OLLAMA_NUM_PARALLEL=2
OLLAMA_MAX_LOADED_MODELS=2
HF_CDSS_LLM_BASE_URL=http://ollama:11434/v1
HF_CDSS_LLM_MODEL=qwen2.5:7b
HF_CDSS_LLM_API_TYPE=chat_completions
HF_CDSS_LLM_TIMEOUT_SECONDS=90
HF_CDSS_LLM_CACHE_ENABLED=true
HF_CDSS_LLM_CACHE_TTL_SECONDS=600
HF_CDSS_LLM_CACHE_MAX_ENTRIES=128
VITE_API_BASE_URL=http://localhost:8000

POSTGRES_USER=hf_cdss
POSTGRES_PASSWORD=hf_cdss
POSTGRES_DB=hf_cdss
POSTGRES_HOST_PORT=55432
NEO4J_AUTH=neo4j/password
HF_CDSS_POSTGRES_DSN=postgresql://hf_cdss:hf_cdss@postgres:5432/hf_cdss
HF_CDSS_NEO4J_URI=bolt://neo4j:7687
HF_CDSS_NEO4J_USER=neo4j
HF_CDSS_NEO4J_PASSWORD=password
HF_CDSS_CHROMA_HOST=chromadb
HF_CDSS_CHROMA_PORT=8000
HF_CDSS_CHROMA_COLLECTION=heart_failure_evidence
LOCALSTACK_HOST_PORT=4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=us-east-1
HF_CDSS_DATA_STORAGE=s3
HF_CDSS_S3_ENDPOINT_URL=http://localstack:4566
HF_CDSS_S3_BUCKET=hf-cdss-data
HF_CDSS_S3_PREFIX=heart_failure
HF_CDSS_DATASTORE_BOOTSTRAP_ON_STARTUP=false
HF_CDSS_RETRIEVAL_BACKEND=hybrid
HF_CDSS_POSTGRES_AUDIT_ENABLED=true
HF_CDSS_POSTGRES_POOL_MIN_SIZE=1
HF_CDSS_POSTGRES_POOL_MAX_SIZE=5
HF_CDSS_VERIFICATION_AGENT_MODE=hybrid
HF_CDSS_VERIFICATION_AGENT_MODEL=qwen2.5:1.5b
HF_CDSS_VERIFICATION_AGENT_MAX_ITERATIONS=1
HF_CDSS_VERIFICATION_AGENT_MAX_TOKENS=140
HF_CDSS_VERIFICATION_AGENT_TIMEOUT_SECONDS=180
HF_CDSS_VERIFICATION_AGENT_WORKERS=2
HF_CDSS_VERIFICATION_AGENT_LLM_AGENTS=evidence_agent,guideline_alignment_agent
HF_CDSS_VERIFICATION_AGENT_TOOL_MODE=direct
HF_CDSS_VERIFICATION_RETRIEVAL_TOP_K=3
HF_CDSS_VERIFICATION_CACHE_ENABLED=true
HF_CDSS_VERIFICATION_CACHE_TTL_SECONDS=300
HF_CDSS_VERIFICATION_CACHE_MAX_ENTRIES=128

AIRFLOW_WEBSERVER_PORT=8080
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin
AIRFLOW_ADMIN_EMAIL=admin@example.com
AIRFLOW_WEBSERVER_SECRET_KEY=hf_cdss_airflow_dev_secret
