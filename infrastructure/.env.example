# Copy to infrastructure/.env and replace the placeholder secrets before running Docker Compose.

# Backend/API access. The frontend build uses the same key by default.
HF_CDSS_API_KEYS=change-me

# JWT auth (backend).
HF_CDSS_JWT_SECRET_KEY=change-me-in-production
HF_CDSS_JWT_ALGORITHM=HS256
HF_CDSS_JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
HF_CDSS_REDIS_URL=redis://:change-me@redis:6379/0
REDIS_PASSWORD=change-me
# Redis is internal to the Docker network only (no host port published).
HF_CDSS_AUTH_LOGIN_ENABLED=true
# Optional override. Copy backend/app/data/seed_users.example.json to seed_users.json locally,
# or set HF_CDSS_AUTH_SEED_USERS_JSON explicitly (escape each $ as $$ in Docker Compose).
HF_CDSS_AUTH_SEED_USERS_JSON=

# Optional cloud override only when HF_CDSS_LLM_BASE_URL points to api.openai.com
OPENAI_API_KEY=
HF_CDSS_LLM_BASE_URL=http://ollama:11434/v1
HF_CDSS_LLM_MODEL=qwen2.5:7b
HF_CDSS_LLM_API_TYPE=chat_completions

# Local model selection.
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_AGENT_MODEL=qwen2.5:1.5b
OLLAMA_EMBEDDING_MODEL=bge-m3
# GPU: Docker Desktop → Settings → Resources enable GPU; compose passes gpus: all to ollama.
# GTX 1650 4GB: keep parallel=1; prefer 1.5b for ingestion (already default via AGENT_MODEL).
OLLAMA_NUM_PARALLEL=1
OLLAMA_MAX_LOADED_MODELS=2
NVIDIA_VISIBLE_DEVICES=all

# Host ports. Change only when these ports are already used on your machine.
POSTGRES_HOST_PORT=55432
LOCALSTACK_HOST_PORT=4566
AIRFLOW_WEBSERVER_PORT=8080
DOCTOR_DASHBOARD_PORT=5173
ADMIN_DASHBOARD_PORT=5174

# Frontend URLs (used at Vite build time in Docker).
VITE_API_BASE_URL=http://localhost:8000
VITE_ADMIN_BASE_URL=http://localhost:5174
VITE_DOCTOR_DASHBOARD_URL=http://localhost:5173

# Development database credentials.
POSTGRES_USER=hf_cdss
POSTGRES_PASSWORD=hf_cdss
POSTGRES_DB=hf_cdss
NEO4J_AUTH=neo4j/password
NEO4J_PASSWORD=password

# Airflow admin account for the local Docker profile.
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin
AIRFLOW_ADMIN_EMAIL=admin@example.com
AIRFLOW_WEBSERVER_SECRET_KEY=change-me-airflow-secret

# Ingestion pipeline tuning (Airflow / scraper on CPU + Ollama).
HF_CDSS_LLM_TIMEOUT_SECONDS=90
HF_CDSS_INGESTION_LLM_TIMEOUT_SECONDS=300
HF_CDSS_INGESTION_LLM_MAX_TOKENS=900
HF_CDSS_LLM_CONCURRENCY=1
HF_CDSS_LLM_MAX_RETRIES=2
HF_CDSS_MAX_LLM_SECTION_CHARS=2500
HF_CDSS_MAX_LLM_CLAIMS_PER_SECTION=12
HF_CDSS_CLAIM_LLM_MIN_PATTERN_MATCHES=3
HF_CDSS_EMBEDDING_PARALLEL_WORKERS=2
HF_CDSS_AIRFLOW_PIPELINE_TIMEOUT_HOURS=48
# Optional overrides; defaults use data/heart_failure/.cache/{embeddings,llm_claims}
# HF_CDSS_EMBEDDING_CACHE_DIR=./data/heart_failure/.embedding_cache
# HF_CDSS_INGESTION_LLM_CACHE_DIR=./data/heart_failure/.ingestion_llm_cache
